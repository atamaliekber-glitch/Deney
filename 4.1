    LIST P=16F628A
    #include <p16f628a.inc>

    ; Konfigürasyon Ayarları
    __CONFIG _FOSC_INTOSCIO & _WDTE_OFF & _PWRTE_ON & _MCLRE_ON & _BOREN_OFF & _LVP_OFF & _CPD_OFF & _CP_OFF

    ; --- DEĞİŞKEN TANIMLAMALARI ---
    CBLOCK 0x20
        VERI1       ; A0-A1'den gelen değer
        VERI2       ; A2-A3'ten gelen değer
        BILGI1      ; Formül 1
        BILGI2      ; Formül 2
        BILGI3      ; Formül 3
        BILGI4      ; Formül 4
        KOD1        ; 7447'ye gidecek şifreli 1. veri
        KOD2        ; 7447'ye gidecek şifreli 2. veri
        KOD3        ; 7447'ye gidecek şifreli 3. veri
        KOD4        ; 7447'ye gidecek şifreli 4. veri
        TEMP        ; Geçici hesaplama register'ı
        SAYAC1      ; Gecikme 1
        SAYAC2      ; Gecikme 2
    ENDC

    ORG 0x000
    GOTO KURULUM

; --- PORT VE PİN KURULUMLARI ---
KURULUM
    MOVLW 0x07          ; Komparatörleri kapat, dijital I/O yap
    MOVWF CMCON

    BSF STATUS, RP0     ; Bank 1'e geç
    MOVLW 0x0F          ; RA0, RA1, RA2, RA3 giriş
    MOVWF TRISA
    CLRF TRISB          ; PORTB'nin tamamı çıkış (RB0-3=7447 Veri, RB4-7=Transistör Seçim)
    BCF STATUS, RP0     ; Bank 0'a dön

; ===============================================================
; 4. AŞAMA GEREĞİ: SONSUZ DÖNGÜ (Değişiklikleri Anında Yakalar)
; ===============================================================
ANA_DONGU
    
    ; --- 1. AŞAMA: GİRİŞLERİN OKUNMASI ---
    MOVF PORTA, W
    ANDLW b'00000011'   
    MOVWF VERI1

    MOVF PORTA, W
    ANDLW b'00001100'   
    MOVWF TEMP
    RRF TEMP, F         
    RRF TEMP, F         
    MOVF TEMP, W
    ANDLW b'00000011'   
    MOVWF VERI2

    ; --- 1. AŞAMA: MATEMATİKSEL HESAPLAMALAR ---
    ; Bilgi1 = 4 x 1.veri + 3
    MOVF VERI1, W
    MOVWF TEMP
    BCF STATUS, C
    RLF TEMP, F         ; x2
    BCF STATUS, C
    RLF TEMP, F         ; x4
    MOVF TEMP, W
    ADDLW .3            
    MOVWF BILGI1

    ; Bilgi2 = 3 x 2.veri + 5
    MOVF VERI2, W
    MOVWF TEMP          ; x1
    ADDWF TEMP, F       ; x2
    ADDWF TEMP, W       ; x3
    ADDLW .5            
    MOVWF BILGI2

    ; Bilgi3 = 2 x 1.veri + 2.veri
    MOVF VERI1, W
    MOVWF TEMP
    BCF STATUS, C
    RLF TEMP, F         ; 2 x VERI1
    MOVF VERI2, W
    ADDWF TEMP, W       
    MOVWF BILGI3

    ; Bilgi4 = 1.veri + 2 x 2.veri
    MOVF VERI2, W
    MOVWF TEMP
    BCF STATUS, C
    RLF TEMP, F         ; 2 x VERI2
    MOVF VERI1, W
    ADDWF TEMP, W       
    MOVWF BILGI4

    ; --- 2. AŞAMA: ÇEVRİM (ŞİFRELEME) TABLOSU UYGULAMASI ---
    MOVF BILGI1, W
    CALL CEVRIM_TABLOSU 
    MOVWF KOD1          

    MOVF BILGI2, W      
    CALL CEVRIM_TABLOSU 
    MOVWF KOD2          

    MOVF BILGI3, W      
    CALL CEVRIM_TABLOSU 
    MOVWF KOD3          

    MOVF BILGI4, W      
    CALL CEVRIM_TABLOSU 
    MOVWF KOD4          

    ; --- 3. AŞAMA: 7 PARÇALI GÖSTERGEDE TARAMA (MULTIPLEXING) ---
    ; Hane 1
    MOVF KOD1, W
    ANDLW 0x0F          
    IORLW b'11100000'   ; RB4 = 0 (1. Transistör aktif)
    MOVWF PORTB
    CALL GECIKME        

    ; Hane 2
    MOVF KOD2, W
    ANDLW 0x0F
    IORLW b'11010000'   ; RB5 = 0 (2. Transistör aktif)
    MOVWF PORTB
    CALL GECIKME

    ; Hane 3
    MOVF KOD3, W
    ANDLW 0x0F
    IORLW b'10110000'   ; RB6 = 0 (3. Transistör aktif)
    MOVWF PORTB
    CALL GECIKME

    ; Hane 4
    MOVF KOD4, W
    ANDLW 0x0F
    IORLW b'01110000'   ; RB7 = 0 (4. Transistör aktif)
    MOVWF PORTB
    CALL GECIKME

    ; 4. Aşama Gereği: Sürekli Kontrol İçin Başa Dön
    GOTO ANA_DONGU


; --- ALT PROGRAM: ÇEVRİM (ŞİFRELEME) TABLOSU ---
CEVRIM_TABLOSU
    ADDWF PCL, F        
    ; NOT: Tablo 1'e göre buradaki dönüşüm değerlerini belirleyebilirsiniz.
    ; Örnek olarak karışık değerler atanmıştır. (0-15 arası değerler alabilir)
    RETLW 0x05          ; Gelen 0 ise 5 çıkar
    RETLW 0x0A          ; Gelen 1 ise 10 çıkar
    RETLW 0x03          
    RETLW 0x08          
    RETLW 0x01          
    RETLW 0x0C          
    RETLW 0x0E          
    RETLW 0x02          
    RETLW 0x09          
    RETLW 0x0F          
    RETLW 0x07          
    RETLW 0x0B          
    RETLW 0x04          
    RETLW 0x0D          
    RETLW 0x06          
    RETLW 0x00          

; --- ALT PROGRAM: MULTIPLEXING GECİKMESİ ---
GECIKME
    MOVLW d'15'         
    MOVWF SAYAC1
GECIKME_DIS
    MOVLW d'100'
    MOVWF SAYAC2
GECIKME_IC
    DECFSZ SAYAC2, F
    GOTO GECIKME_IC
    DECFSZ SAYAC1, F
    GOTO GECIKME_DIS
    
    MOVLW b'11110000'   ; Ghosting (gölgelenme) olmaması için transistörleri kapat
    MOVWF PORTB
    RETURN

    END

